{
  "manifest_version": 3,
  "name": "RepUp — Duolingo for devs",
  "version": "1.1.0",
  "description": "Streak your commits, level up, beat the daily code challenge — plus a real-time AI code review sidebar on every GitHub PR and file.",
  "key": "",
  "action": {
    "default_title": "Open RepUp"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel",
    "identity",
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://*.firebaseio.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseapp.com/*",
    "https://github.com/*",
    "https://repup-backend-5gl2pr26hq-uc.a.run.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "content/config.js",
        "content/gh-review.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
